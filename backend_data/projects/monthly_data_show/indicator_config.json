  "calculated_section": {
    "title": "计算指标（19项）"
  },
  "calculated_items": [
    { "name": "供暖热耗率", "unit": "吉焦/平方米", "formula": "{{供暖耗热量}} / {{期末供暖收费面积}}" },
    { "name": "供暖水耗率", "unit": "千克/平方米", "formula": "{{热网耗水量}} * 1000 / {{期末供暖收费面积}}" },
    { "name": "供暖电耗率", "unit": "千瓦时/平方米", "formula": "{{热网耗电量}} * 10000 / {{期末供暖收费面积}}" },
    { "name": "供暖标准煤耗率", "unit": "千克/平方米", "formula": "{{供热耗标煤量}} * 1000 / {{期末供暖收费面积}}" },
    { "name": "综合厂用电率", "unit": "%", "formula": "{{综合厂用电量}} / {{发电量}}" },
    { "name": "发电厂用电率", "unit": "%", "formula": "{{发电厂用电量}} / {{发电量}}" },
    { "name": "供热厂用电率", "unit": "千瓦时/吉焦", "formula": "{{供热厂用电量}} * 10000 / {{供热量}}" },
    { "name": "全厂热效率", "unit": "%", "formula": "({{供热量}} + {{售电量}} * 36) / ({{耗标煤总量}} * 29.308)" },
    { "name": "热电比", "unit": "%", "formula": "{{供热量}} / ({{售电量}} * 36)" },
    { "name": "热分摊比", "unit": "%", "formula": "{{供热耗标煤量}} / {{耗标煤总量}}" },
    { "name": "发电标准煤耗率", "unit": "克/千瓦时", "formula": "{{发电耗标煤量}} * 100 / {{发电量}}" },
    { "name": "供电标准煤耗率", "unit": "克/千瓦时", "formula": "{{发电耗标煤量}} * 100 / ({{发电量}} - {{发电厂用电量}})" },
    { "name": "供热标准煤耗率", "unit": "千克/吉焦", "formula": "{{供热耗标煤量}} * 1000 / {{供热量}}" },
    { "name": "发电水耗率", "unit": "吨/万千瓦时", "formula": "({{耗水量}} - {{供汽量}} - {{热网耗水量}}) * (1 - {{热分摊比}}) / {{发电量}}" },
    { "name": "供热水耗率", "unit": "吨/吉焦", "formula": "(({{耗水量}} - {{供汽量}} - {{热网耗水量}}) * {{热分摊比}} + {{供汽量}} + {{热网耗水量}}) / {{供热量}}" },
    { "name": "发电设备利用率", "unit": "%", "formula": "{{发电量}} / {{发电设备容量}} / ({{天数}} * 24)" },
    { "name": "供热设备利用率", "unit": "%", "formula": "{{供热量}} * 1000 / {{锅炉设备容量}} / (({{天数}} * 24) * 3600)" },
    { "name": "入炉煤低位发热量", "unit": "千焦/千克", "formula": "({{耗标煤总量}} - 1.4571 * {{耗油量}}) * 29308 / {{生产耗原煤量}}" },
    { "name": "供热用电率", "unit": "千瓦时/吉焦", "formula": "{{耗电量}} * 10000 / {{供热量}}" }
  ]
}
